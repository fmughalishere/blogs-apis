PORT=5000

# MongoDB connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/blogs

# JWT
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Cookie / CORS — comma-separated list, one origin per frontend
CLIENT_URL=http://localhost:3000,http://localhost:3001

# Secret code required to register a new ADMIN account
ADMIN_REGISTER_SECRET=replace-with-a-secret-code

# Cloudinary configuration
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
